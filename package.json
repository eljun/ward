{
  "name": "ward",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "ward": "./apps/cli/src/main.ts"
  },
  "scripts": {
    "ward": "bun run apps/cli/src/main.ts",
    "dev:runtime": "bun run apps/runtime/src/index.ts",
    "dev:ui": "cd apps/ui && bun run dev",
    "build": "bun run build:ui && bun run typecheck && bun run lint:layers && bun run lint:layers:fixture",
    "build:ui": "cd apps/ui && bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:layers": "depcruise --config .dependency-cruiser.cjs apps packages",
    "lint:layers:fixture": "bun run scripts/check-layer-fixture.ts",
    "test": "bun test"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "dependency-cruiser": "^17.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}

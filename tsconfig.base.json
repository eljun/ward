{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "bun"
    ],
    "paths": {
      "@ward/core": [
        "./packages/core/src/index.ts"
      ],
      "@ward/memory": [
        "./packages/memory/src/index.ts"
      ]
    }
  }
}
